rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ==========================================
    // Funções Auxiliares
    // ==========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (request.auth.token.admin == true || request.auth.uid == 'N4oCVnsPILZivmlgLo4jC7Bq8GU2');
    }
    
    // REDUZIDO PARA 1MB: Valida se é imagem e se é menor que 1MB (1 * 1024 * 1024 bytes)
    function isValidImage() {
      return request.resource.contentType.matches('image/.*') 
             && request.resource.size < 1 * 1024 * 1024;
    }

    // ==========================================
    // Regras por Caminho (Marketplace)
    // ==========================================

    match /users/{userId}/{allImages=**} {
      allow read: if true;
      allow write: if (isAuthenticated() && request.auth.uid == userId && isValidImage()) || isAdmin();
      allow delete: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
    }

    match /ads/{userId}/{allImages=**} {
      allow read: if true;
      allow write: if (isAuthenticated() && request.auth.uid == userId && isValidImage()) || isAdmin();
      allow delete: if (isAuthenticated() && request.auth.uid == userId) || isAdmin();
    }

    match /verifications/{userId}/{allImages=**} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if (isAuthenticated() && request.auth.uid == userId && request.resource.contentType.matches('image/.*') && request.resource.size < 5 * 1024 * 1024) || isAdmin();
      allow delete: if isAdmin();
    }

    match /chats/{chatId}/{allImages=**} {
      allow read, write: if isAuthenticated() && isValidImage();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
