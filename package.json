{
  "name": "reparauto",
  "version": "4.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:app": "cross-env BUILD_TARGET=app next build",
    "start": "next start",
    "lint": "next lint",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:hosting": "firebase deploy --only apphosting",
    "firebase:config": "node scripts/copy-firebase-config.mjs",
    "cap:sync": "npm run build:app && cap sync && npm run firebase:config",
    "cap:android": "npm run cap:sync && cap open android",
    "cap:ios": "npm run cap:sync && cap open ios",
    "debug:android": "npm run cap:sync && cap run android",
    "debug:ios": "npm run cap:sync && cap run ios",
    "debug:android:live": "cap run android --live-reload --external",
    "debug:ios:live": "cap run ios --live-reload --external"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor-firebase/messaging": "^8.2.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.3.4",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@types/leaflet": "^1.9.21",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
