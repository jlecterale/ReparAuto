{
  "name": "reparauto",
  "version": "4.0.0",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || exit 0",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "studio": "npm --prefix video run studio -- --port 4000",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:firestore": "firebase deploy --only firestore",
    "deploy:hosting": "firebase deploy --only apphosting",
    "import:pecas": "node scripts/importar-pecas.mjs",
    "import:pecas:dry": "node scripts/importar-pecas.mjs --dry-run",
    "generate:dashboard": "node scripts/generate-dashboard.mjs",
    "migrate:reviews": "node scripts/migrate-reviews.mjs",
    "migrate:reviews:dry": "node scripts/migrate-reviews.mjs --dry-run"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@types/leaflet": "^1.9.21",
    "firebase": "^12.13.0",
    "firebase-admin": "^13.10.0",
    "leaflet": "^1.9.4",
    "next": "^16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "fake-indexeddb": "^6.2.5",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
