{
  "name": "recargarage-video",
  "version": "1.0.0",
  "description": "RecarGarage — geração de vídeos de marketing (Remotion) para Instagram, Google Ads e YouTube",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@remotion/cli": "4.0.484",
    "@remotion/google-fonts": "^4.0.484",
    "@remotion/shapes": "^4.0.484",
    "@remotion/tailwind-v4": "4.0.484",
    "@remotion/transitions": "^4.0.484",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.484",
    "tailwindcss": "4.0.0"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.484",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "studio": "remotion studio",
    "build": "remotion bundle",
    "render": "remotion render RecarGaragePromo out/RecarGarage-promo.mp4",
    "render:square": "remotion render RecarGaragePromoSquare out/RecarGarage-promo-1x1.mp4",
    "render:wide": "remotion render RecarGaragePromoWide out/RecarGarage-promo-16x9.mp4",
    "render:all": "npm run render && npm run render:square && npm run render:wide",
    "upgrade": "remotion upgrade",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src && tsc"
  },
  "sideEffects": [
    "*.css"
  ]
}
