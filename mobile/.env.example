
# --- EAS (build + OTA updates) ---
# Project id printed by `eas init`. Powers `extra.eas.projectId` and the EAS
# Update endpoint (https://u.expo.dev/<id>). Without it, OTA stays disabled and
# the app simply runs its bundled JS. See docs/OTA-UPDATES.md.
EAS_PROJECT_ID=

# --- Android release signing (read by `npm run android:bundle`/`android:release`) ---
# Generate once:  keytool -genkeypair -v -keystore ~/keystores/recargarage-upload.jks \
#   -storetype JKS -alias recargarage-upload -keyalg RSA -keysize 2048 -validity 10000
# Then register the keystore SHA-1 in Firebase (Google Sign-In) and Play.
RG_UPLOAD_STORE_FILE=$HOME/keystores/recargarage-upload.jks
RG_UPLOAD_KEY_ALIAS=recargarage-upload
RG_UPLOAD_STORE_PASSWORD=
RG_UPLOAD_KEY_PASSWORD=

# --- iOS release / App Store Connect (read by `npm run ios:release`) ---
# Apple Developer Team ID (Membership page). Defaults to DLB2RYLUDX in the script.
APPLE_TEAM_ID=
# App Store Connect API key: App Store Connect → Users and Access → Integrations
# → App Store Connect API. Download AuthKey_<KEY_ID>.p8 once and put it at
# ~/.appstoreconnect/private_keys/ (or set ASC_KEY_PATH).
ASC_KEY_ID=
ASC_ISSUER_ID=
# ASC_KEY_PATH=$HOME/.appstoreconnect/private_keys/AuthKey_${ASC_KEY_ID}.p8

# --- Google Sign-In ---
# Reversed iOS OAuth client id (REVERSED_CLIENT_ID from GoogleService-Info.plist).
EXPO_PUBLIC_GOOGLE_REVERSED_CLIENT_ID=
# Web OAuth client id (type 3). Firebase Console → Authentication → Sign-in
# method → Google → "Web SDK configuration", or Google Cloud → APIs & Services
# → Credentials → "Web client". Required for Android Google Sign-In; on iOS the
# client id is read automatically from GoogleService-Info.plist.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=707836120678-fnnultrqru0rj182o8f558b687mmjq6v.apps.googleusercontent.com
