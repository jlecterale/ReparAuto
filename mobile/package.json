{
  "name": "recargarage-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "android:release": "expo prebuild --platform android --clean && cd android && ./gradlew assembleRelease -x lintVitalRelease",
    "android:bundle": "expo prebuild --platform android && cd android && ./gradlew bundleRelease -x lintVitalRelease",
    "android:install": "expo prebuild --platform android && cd android && (test -x ./gradlew && ./gradlew :app:installRelease || gradle :app:installRelease)",
    "android:submit": "eas build --profile production --platform android --submit",
    "ios:prod": "expo prebuild --platform ios --clean && expo run:ios --configuration Release",
    "ios:archive": "scripts/build-ios.sh archive",
    "ios:export": "scripts/build-ios.sh export",
    "ios:upload": "scripts/build-ios.sh upload",
    "ios:release": "scripts/build-ios.sh release",
    "ios": "expo run:ios",
    "archive:ios": "bash scripts/build-ios.sh archive",
    "export:ios": "bash scripts/build-ios.sh export",
    "upload:ios": "bash scripts/build-ios.sh upload",
    "release:ios": "bash scripts/build-ios.sh release",
    "prebuild": "expo prebuild",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "update": "eas update",
    "update:preview": "eas update --branch preview",
    "update:production": "eas update --branch production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/app": "^24.1.1",
    "@react-native-firebase/auth": "^24.1.1",
    "@react-native-firebase/firestore": "^24.1.1",
    "@react-native-firebase/messaging": "^24.1.1",
    "@react-native-firebase/storage": "^24.1.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "babel-preset-expo": "~55.0.8",
    "expo": "~55.0.26",
    "expo-apple-authentication": "~55.0.13",
    "expo-build-properties": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-dev-client": "~55.0.35",
    "expo-font": "~55.0.8",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.11",
    "expo-image-manipulator": "~55.0.18",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-location": "~55.1.10",
    "expo-network": "~55.0.14",
    "expo-notifications": "~55.0.23",
    "expo-router": "~55.0.16",
    "expo-secure-store": "~55.0.14",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.18",
    "expo-updates": "~55.0.24",
    "expo-web-browser": "~55.0.16",
    "nativewind": "^4.2.5",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.2.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.2"
  }
}
