rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        request.auth.uid == 'N4oCVnsPILZivmlgLo4jC7Bq8GU2' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    function isCreatorByEmail() {
      return isAuthenticated() && request.resource.data.criador == request.auth.token.email;
    }
    function isOwnerByEmail() {
      return isAuthenticated() && resource.data.criador == request.auth.token.email;
    }
    function hasValidImageCount(maxLimit) {
      let data = request.resource.data;
      let hasFotos = 'fotos' in data;
      return !hasFotos || data.fotos.size() <= maxLimit;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    match /cars/{carId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasValidImageCount(7);
      allow update: if (isOwnerByEmail() && hasValidImageCount(7)) || isAdmin()
        // Visualizações: qualquer visitante (mesmo não logado)
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['visualizacoes'])
        // Mensagens e favoritos: apenas autenticados
        || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['contagemMensagens', 'contagemFavoritos']));
      allow delete: if isOwnerByEmail() || isAdmin();
    }

    match /parts/{partId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasValidImageCount(3);
      allow update: if (isOwnerByEmail() && hasValidImageCount(3)) || isAdmin()
        // Visualizações: qualquer visitante
        || request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['visualizacoes'])
        // Mensagens: apenas autenticados
        || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['contagemMensagens']));
      allow delete: if isOwnerByEmail() || isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAuthenticated() && hasValidImageCount(7);
      allow update: if (isOwnerByEmail() && hasValidImageCount(7)) || isAdmin();
      allow delete: if isOwnerByEmail() || isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.uid;
      // 'mensagem' and 'info' may target other users: chat notifications and
      // "new pending listing" alerts sent by regular users to admins.
      allow create: if isAuthenticated() && (isAdmin() || request.auth.uid == request.resource.data.uid || request.resource.data.tipo in ['mensagem', 'info']);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.uid;
      allow delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.participants ||
        request.auth.uid == resource.data.fromUid ||
        request.auth.uid == resource.data.toUid
      );
      allow create: if isAuthenticated() && request.resource.data.fromUid == request.auth.uid && request.resource.data.fromUid != request.resource.data.toUid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.fromUid || request.auth.uid == resource.data.toUid);
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.autorUid == request.auth.uid
        && request.resource.data.vendedorEmail != request.auth.token.email
        && request.resource.data.nota >= 1
        && request.resource.data.nota <= 5
        && request.resource.data.status == 'pendente';
      allow update: if isAdmin();
      allow delete: if isAuthenticated() && (resource.data.autorUid == request.auth.uid || isAdmin());
    }

    match /reports/{reportId} {
      allow read: if isAdmin()
        || (isAuthenticated() && resource.data.denuncianteUid == request.auth.uid);
      allow create: if isAuthenticated()
        && request.resource.data.denuncianteUid == request.auth.uid
        && request.resource.data.status == 'pendente';
      allow update: if isAdmin();
    }

    match /verifications/{verificationId} {
      allow read: if isAuthenticated() && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isAuthenticated()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == 'pendente';
      allow update: if isAdmin();
    }

    match /intencoes_compra/{intencaoId} {
      allow read: if true;
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid;
      // Any signed-in user may bump view/contact counters (stats map only),
      // mirroring the counter exception on /cars and /parts.
      allow update: if (isAuthenticated() && request.auth.uid == resource.data.userId) || isAdmin()
        || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['stats']));
      allow delete: if (isAuthenticated() && request.auth.uid == resource.data.userId) || isAdmin();
    }

    match /contatos_intencao/{contatoId} {
      allow read: if (isAuthenticated() && (
        request.auth.uid == get(/databases/$(database)/documents/intencoes_compra/$(resource.data.intencaoId)).data.userId ||
        request.auth.uid == resource.data.vendedorId
      )) || isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.vendedorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        request.auth.uid == get(/databases/$(database)/documents/intencoes_compra/$(resource.data.intencaoId)).data.userId ||
        request.auth.uid == resource.data.vendedorId
      );
    }

    match /marcas_modelos/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /denuncias_intencao/{denunciaId} {
      allow read: if (isAuthenticated() && request.auth.uid == resource.data.denunciantId) || isAdmin();
      allow create: if isAuthenticated()
        && request.resource.data.denunciantId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /propostas/{propostaId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.vendedorUid ||
        request.auth.uid == resource.data.compradorUid ||
        isAdmin()
      );
      allow create: if isAuthenticated()
        && request.resource.data.vendedorUid == request.auth.uid
        && request.resource.data.status == 'pendente';
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.compradorUid ||
        request.auth.uid == resource.data.vendedorUid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    match /leads_parceria/{leadId} {
      // Consent-gated lead intake; readable only by admins (RGPD).
      allow read: if isAdmin();
      allow create: if request.resource.data.consentimento == true;
      allow update, delete: if isAdmin();
    }

    match /seller_daily/{docId} {
      // Per-seller engagement buckets. Readable only by the seller; metric
      // fields may be bumped by anyone (incl. anonymous viewers), mirroring the
      // `visualizacoes` counter exception on /cars. No sensitive data lives here.
      allow read: if isAuthenticated() && request.auth.uid == resource.data.ownerUid;
      allow create: if request.resource.data.keys()
        .hasOnly(['ownerUid', 'date', 'views', 'contacts', 'updatedAt']);
      // setDoc(merge) re-sends ownerUid/date with identical values on every
      // bump; allow them in affectedKeys so a no-op rewrite can't fail the rule.
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['ownerUid', 'date', 'views', 'contacts', 'updatedAt']);
    }

    match /clients/{clientId} {
      // A professional's private client book — strictly owner-scoped. The owner
      // controls their own records, so forging `matchedUserUid` only ever links
      // to an already-public profile (no data leak).
      allow read, delete: if isAuthenticated() && request.auth.uid == resource.data.ownerUid;
      allow create: if isAuthenticated() && request.resource.data.ownerUid == request.auth.uid;
      // Owner-only, and ownerUid is immutable (can't re-home a record onto someone else).
      allow update: if isAuthenticated()
        && request.auth.uid == resource.data.ownerUid
        && request.resource.data.ownerUid == resource.data.ownerUid;
    }

    match /config/{document} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
